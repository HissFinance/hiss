{
  "name": "@hiss-finance/mcp-server",
  "version": "0.1.0",
  "description": "Local stdio MCP server for HISS Finance — read-and-prepare tools only. Never exposes keys, never signs, never performs owner-only or admin actions.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "hiss-mcp": "dist/bin/server.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/bin/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hiss-finance/core": "workspace:*",
    "@hiss-finance/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
