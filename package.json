{
  "name": "hiss-finance",
  "version": "0.1.0",
  "private": true,
  "description": "HISS Finance — open-source packages, schemas, contract ABIs, and examples for the CoilOps workbench, USDG Creator Vaults, and $HISS token surfaces.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r --if-present lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "examples:build": "tsx scripts/build-examples.ts",
    "contracts:test": "tsx scripts/contracts-test.ts",
    "schemas:validate": "tsx scripts/validate-schemas.ts",
    "docs:check": "tsx scripts/check-doc-links.ts",
    "check:private-boundary": "tsx scripts/check-private-boundary.ts",
    "check:execution-claims": "tsx scripts/check-execution-claims.ts",
    "check:fee-docs": "tsx scripts/check-fee-docs.ts",
    "check:secrets": "tsx scripts/check-secrets.ts",
    "licenses:check": "tsx scripts/check-licenses.ts",
    "check:all": "pnpm schemas:validate && pnpm docs:check && pnpm check:private-boundary && pnpm check:execution-claims && pnpm check:fee-docs && pnpm check:secrets && pnpm licenses:check"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
