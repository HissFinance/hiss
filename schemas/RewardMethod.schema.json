{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiss.finance/schemas/RewardMethod.schema.json",
  "title": "RewardMethod",
  "version": "2.0.0",
  "description": "HISS_REWARD_METHOD_V2 — the public reward methodology. Verified $HISS trading fees split 50/15/15/10/10 (xHISS stakers / vault providers / vault contributors / treasury / economic burn; legs sum to 10,000 bps, treasury absorbs floor-division dust). 'Vault contributors' is the current name for the former depositor cohort; rewards are allocated by share-seconds and vest linearly over 30 days. Vault-provider rewards are quality-weighted (40% equal / 30% external-TVL-days / 20% retention / 10% operational), dominance-capped at 25% of the pool, and vest over 90 days. The burn leg is an ECONOMIC burn to the canonical dead address (0x…dEaD) that does NOT reduce HISS.totalSupply. No performance (PnL/APY/rank/volatility) inputs anywhere. V1 (50/30/10/10, no burn) is historical.",
  "type": "object",
  "required": ["version", "split", "vaultContributor", "vaultProvider", "burn", "authorization"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": "HISS_REWARD_METHOD_V2" },
    "split": {
      "type": "object",
      "required": ["xHissStakerBps", "vaultProviderBps", "vaultContributorBps", "treasuryBps", "burnBps"],
      "additionalProperties": false,
      "properties": {
        "xHissStakerBps": { "const": 5000 },
        "vaultProviderBps": { "const": 1500 },
        "vaultContributorBps": { "const": 1500 },
        "treasuryBps": { "const": 1000 },
        "burnBps": { "const": 1000 }
      }
    },
    "vaultContributor": {
      "type": "object",
      "required": ["basis", "vestSeconds", "dustPolicy"],
      "additionalProperties": false,
      "properties": {
        "basis": { "const": "share_seconds" },
        "vestSeconds": { "const": 2592000, "description": "30-day linear vest." },
        "dustPolicy": { "type": "string" }
      }
    },
    "vaultProvider": {
      "type": "object",
      "required": [
        "components",
        "dominanceCapBps",
        "vestSeconds",
        "dustPolicy",
        "performanceInputsForbidden"
      ],
      "additionalProperties": false,
      "properties": {
        "components": {
          "type": "object",
          "required": ["equalBps", "externalTvlBps", "retentionBps", "operationalBps"],
          "additionalProperties": false,
          "properties": {
            "equalBps": { "const": 4000 },
            "externalTvlBps": { "const": 3000 },
            "retentionBps": { "const": 2000 },
            "operationalBps": { "const": 1000 }
          }
        },
        "dominanceCapBps": {
          "const": 2500,
          "description": "No provider group may take more than 25% of the pool."
        },
        "vestSeconds": { "const": 7776000, "description": "90-day linear vest." },
        "dustPolicy": { "type": "string" },
        "performanceInputsForbidden": { "const": true }
      }
    },
    "burn": {
      "type": "object",
      "required": ["kind", "sink", "reducesTotalSupply"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "economic_burn" },
        "sink": {
          "const": "0x000000000000000000000000000000000000dEaD",
          "description": "Canonical dead address; HISS routed here leaves circulation but totalSupply is unchanged."
        },
        "reducesTotalSupply": { "const": false }
      }
    },
    "authorization": {
      "type": "object",
      "required": ["finalizationRequiresSafe", "safeThreshold"],
      "additionalProperties": false,
      "properties": {
        "finalizationRequiresSafe": { "const": true },
        "safeThreshold": { "const": 2 }
      }
    }
  },
  "examples": [
    {
      "version": "HISS_REWARD_METHOD_V2",
      "split": {
        "xHissStakerBps": 5000,
        "vaultProviderBps": 1500,
        "vaultContributorBps": 1500,
        "treasuryBps": 1000,
        "burnBps": 1000
      },
      "vaultContributor": {
        "basis": "share_seconds",
        "vestSeconds": 2592000,
        "dustPolicy": "unallocated_rolls_to_treasury_after_deadline"
      },
      "vaultProvider": {
        "components": {
          "equalBps": 4000,
          "externalTvlBps": 3000,
          "retentionBps": 2000,
          "operationalBps": 1000
        },
        "dominanceCapBps": 2500,
        "vestSeconds": 7776000,
        "dustPolicy": "rollover_to_next_epoch",
        "performanceInputsForbidden": true
      },
      "burn": {
        "kind": "economic_burn",
        "sink": "0x000000000000000000000000000000000000dEaD",
        "reducesTotalSupply": false
      },
      "authorization": { "finalizationRequiresSafe": true, "safeThreshold": 2 }
    }
  ]
}
