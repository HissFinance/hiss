{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiss.finance/schemas/RewardMethod.schema.json",
  "title": "RewardMethod",
  "version": "1.0.0",
  "description": "HISS_REWARD_METHOD_V1 — the public reward methodology. Verified $HISS trading fees split 50/30/10/10 (xHISS stakers / depositor vesting / provider rewards / treasury; legs sum to 10,000 bps, treasury absorbs floor-division dust). Depositor rewards are allocated by share-seconds and vest linearly over 30 days. Provider rewards are quality-weighted (40% equal / 30% external-TVL-days / 20% retention / 10% operational), dominance-capped at 25% of the pool, and vest over 90 days. No performance (PnL/APY/rank/volatility) inputs anywhere.",
  "type": "object",
  "required": ["version", "split", "depositor", "provider", "authorization"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": "HISS_REWARD_METHOD_V1" },
    "split": {
      "type": "object",
      "required": ["xHissStakerBps", "depositorBps", "providerBps", "treasuryBps"],
      "additionalProperties": false,
      "properties": {
        "xHissStakerBps": { "const": 5000 },
        "depositorBps": { "const": 3000 },
        "providerBps": { "const": 1000 },
        "treasuryBps": { "const": 1000 }
      }
    },
    "depositor": {
      "type": "object",
      "required": ["basis", "vestSeconds", "dustPolicy"],
      "additionalProperties": false,
      "properties": {
        "basis": { "const": "share_seconds" },
        "vestSeconds": { "const": 2592000, "description": "30-day linear vest." },
        "dustPolicy": { "type": "string" }
      }
    },
    "provider": {
      "type": "object",
      "required": [
        "components",
        "dominanceCapBps",
        "vestSeconds",
        "dustPolicy",
        "performanceInputsForbidden"
      ],
      "additionalProperties": false,
      "properties": {
        "components": {
          "type": "object",
          "required": ["equalBps", "externalTvlBps", "retentionBps", "operationalBps"],
          "additionalProperties": false,
          "properties": {
            "equalBps": { "const": 4000 },
            "externalTvlBps": { "const": 3000 },
            "retentionBps": { "const": 2000 },
            "operationalBps": { "const": 1000 }
          }
        },
        "dominanceCapBps": {
          "const": 2500,
          "description": "No provider group may take more than 25% of the pool."
        },
        "vestSeconds": { "const": 7776000, "description": "90-day linear vest." },
        "dustPolicy": { "type": "string" },
        "performanceInputsForbidden": { "const": true }
      }
    },
    "authorization": {
      "type": "object",
      "required": ["finalizationRequiresSafe", "safeThreshold"],
      "additionalProperties": false,
      "properties": {
        "finalizationRequiresSafe": { "const": true },
        "safeThreshold": { "const": 2 }
      }
    }
  },
  "examples": [
    {
      "version": "HISS_REWARD_METHOD_V1",
      "split": { "xHissStakerBps": 5000, "depositorBps": 3000, "providerBps": 1000, "treasuryBps": 1000 },
      "depositor": {
        "basis": "share_seconds",
        "vestSeconds": 2592000,
        "dustPolicy": "unallocated_rolls_to_treasury_after_deadline"
      },
      "provider": {
        "components": {
          "equalBps": 4000,
          "externalTvlBps": 3000,
          "retentionBps": 2000,
          "operationalBps": 1000
        },
        "dominanceCapBps": 2500,
        "vestSeconds": 7776000,
        "dustPolicy": "rollover_to_next_epoch",
        "performanceInputsForbidden": true
      },
      "authorization": { "finalizationRequiresSafe": true, "safeThreshold": 2 }
    }
  ]
}
