{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiss.finance/schemas/VaultCandidate.schema.json",
  "title": "VaultCandidate",
  "version": "1.0.0",
  "description": "A pre-publication draft of a HISS USDG Creator Vault. A candidate is always free to save and does NOT require creator skin-in-the-game; it becomes a VaultManifest (and pays the 50 USDG publish fee, and the deposit gate + skin apply) only when published on-chain.",
  "type": "object",
  "required": [
    "candidateVersion",
    "slug",
    "name",
    "description",
    "chainId",
    "baseAsset",
    "allowedAssetSymbols",
    "feeConfig",
    "creatorWalletAddress",
    "saveFeeUsdg",
    "status",
    "createdAt"
  ],
  "additionalProperties": false,
  "properties": {
    "candidateVersion": { "const": "vault-candidate-1.0.0" },
    "slug": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "chainId": { "type": "integer", "enum": [4663, 46630] },
    "baseAsset": { "const": "USDG" },
    "allowedAssetSymbols": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "feeConfig": { "$ref": "https://hiss.finance/schemas/FeeSchedule.schema.json" },
    "creatorWalletAddress": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "saveFeeUsdg": { "const": 0, "description": "Candidates are always free to save." },
    "status": { "const": "candidate" },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "examples": [
    {
      "candidateVersion": "vault-candidate-1.0.0",
      "slug": "draft-momentum",
      "name": "Draft Momentum",
      "description": "A candidate not yet published on-chain.",
      "chainId": 4663,
      "baseAsset": "USDG",
      "allowedAssetSymbols": ["USDG", "QQQ"],
      "feeConfig": {
        "performanceFeeBps": 1000,
        "protocolShareBps": 1000,
        "routingFeeTenthBps": 0,
        "creatorFeeRecipient": "0x1111111111111111111111111111111111111111"
      },
      "creatorWalletAddress": "0x1111111111111111111111111111111111111111",
      "saveFeeUsdg": 0,
      "status": "candidate",
      "createdAt": "2026-01-01T00:00:00.000Z"
    }
  ]
}
