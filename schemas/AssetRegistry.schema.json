{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiss.finance/schemas/AssetRegistry.schema.json",
  "title": "AssetRegistry",
  "version": "1.0.0",
  "description": "Public asset registry: USDG (the 6-decimal vault base asset) and $HISS (the 18-decimal protocol token). Decimals are load-bearing — USDG is 6, never 18.",
  "type": "array",
  "items": { "$ref": "#/$defs/asset" },
  "$defs": {
    "asset": {
      "type": "object",
      "required": ["symbol", "address", "chainId", "decimals", "assetClass", "role", "issuer"],
      "additionalProperties": false,
      "properties": {
        "symbol": { "type": "string" },
        "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
        "chainId": { "type": "integer", "enum": [4663, 46630] },
        "decimals": { "type": "integer", "minimum": 0, "maximum": 18 },
        "assetClass": { "type": "string", "enum": ["stablecoin", "governance_token"] },
        "role": { "type": "string", "enum": ["base_asset", "protocol_token"] },
        "issuer": { "type": "string" }
      }
    }
  },
  "examples": [
    [
      {
        "symbol": "USDG",
        "address": "0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168",
        "chainId": 4663,
        "decimals": 6,
        "assetClass": "stablecoin",
        "role": "base_asset",
        "issuer": "Paxos (Global Dollar Network)"
      },
      {
        "symbol": "HISS",
        "address": "0x47162135cc8fb253f939Bd70e3D2B83075eaeBa3",
        "chainId": 4663,
        "decimals": 18,
        "assetClass": "governance_token",
        "role": "protocol_token",
        "issuer": "HISS Finance"
      }
    ]
  ]
}
