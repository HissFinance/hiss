{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiss.finance/schemas/CoilManifest.schema.json",
  "title": "CoilManifest",
  "version": "1.0.0",
  "description": "A structured, versioned trading thesis: an allocation core plus policy, risk fuses, and triggers. Allocation weights must sum to EXACTLY 10,000 basis points. Token addresses are identity; brokerage tickers are a separate, explicit mapping and are never 0x addresses.",
  "type": "object",
  "required": [
    "schemaVersion",
    "coilId",
    "slug",
    "name",
    "version",
    "whisper",
    "chainId",
    "allocations",
    "brokerSymbols",
    "rebalance",
    "fuses",
    "triggers",
    "executionMode",
    "createdAt",
    "updatedAt"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "coil-1.0.0" },
    "coilId": { "type": "string" },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "whisper": {
      "type": "string",
      "minLength": 1,
      "description": "The raw market idea this Coil was coiled from."
    },
    "chainId": { "type": "integer", "enum": [4663, 46630] },
    "allocations": {
      "type": "array",
      "minItems": 1,
      "description": "Holdings by on-chain address. Weights (bps) sum to exactly 10,000.",
      "items": { "$ref": "#/$defs/allocation" }
    },
    "brokerSymbols": { "type": "array", "items": { "$ref": "#/$defs/brokerSymbol" } },
    "rebalance": { "$ref": "#/$defs/rebalance" },
    "fuses": { "$ref": "https://hiss.finance/schemas/FuseSet.schema.json" },
    "triggers": { "type": "array", "items": { "type": "object" } },
    "executionMode": {
      "type": "string",
      "enum": ["paper_only", "preview_only", "human_confirm", "agentic_mcp_enabled"]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "forkOf": { "type": "string" }
  },
  "$defs": {
    "allocation": {
      "type": "object",
      "required": ["ticker", "tokenAddress", "weightBps"],
      "additionalProperties": false,
      "properties": {
        "ticker": { "type": "string" },
        "tokenAddress": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
        "weightBps": { "type": "integer", "exclusiveMinimum": 0, "maximum": 10000 },
        "rationale": { "type": "string" }
      }
    },
    "brokerSymbol": {
      "type": "object",
      "required": ["symbol", "registryTicker"],
      "additionalProperties": false,
      "properties": {
        "symbol": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9.]{0,9}$",
          "description": "Plain brokerage ticker; never a 0x address."
        },
        "registryTicker": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "rebalance": {
      "type": "object",
      "required": ["method", "driftThresholdBps", "minTradeUsd", "maxSlippageBps"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "enum": ["drift", "calendar", "hybrid", "manual"] },
        "driftThresholdBps": { "type": "integer", "minimum": 0 },
        "minTradeUsd": { "type": "number", "minimum": 0 },
        "maxSlippageBps": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "examples": [
    {
      "schemaVersion": "coil-1.0.0",
      "coilId": "coil-9a1b2c3d",
      "slug": "semis-coil",
      "name": "Semis Coil",
      "version": 1,
      "whisper": "semis look coiled into earnings",
      "chainId": 4663,
      "allocations": [
        { "ticker": "NVDA", "tokenAddress": "0x1111111111111111111111111111111111111111", "weightBps": 6000 },
        { "ticker": "AMD", "tokenAddress": "0x2222222222222222222222222222222222222222", "weightBps": 4000 }
      ],
      "brokerSymbols": [
        { "symbol": "NVDA", "registryTicker": "NVDA" },
        { "symbol": "AMD", "registryTicker": "AMD" }
      ],
      "rebalance": { "method": "drift", "driftThresholdBps": 500, "minTradeUsd": 10, "maxSlippageBps": 50 },
      "fuses": [
        { "kind": "maxPositionWeight", "maxBps": 6000 },
        { "kind": "maxSingleOrderNotional", "maxUsd": 500 },
        { "kind": "maxDailyTurnover", "maxBps": 2000 },
        { "kind": "noOptions" },
        { "kind": "noMargin" }
      ],
      "triggers": [{ "kind": "manualReview" }],
      "executionMode": "paper_only",
      "createdAt": "2026-01-01T00:00:00.000Z",
      "updatedAt": "2026-01-01T00:00:00.000Z"
    }
  ]
}
